.container {
    display: flex;
    justify-content: center;
    align-content: center;
    height: 100vh;
    flex-wrap: wrap;
    background-color: #f3de8a;
}

.blog-post {
    padding: 30px;
    border: 1px solid black;
    border-radius: 10px;
    color: var(--text-color);
    background-color: var(--main-color);
    &__title {
        font-size: 48px;
        padding: 15px 0;
    }
    &__text {
        font-size: 24px;
        padding: 15px 0;
    }
}